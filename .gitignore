# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Node / pnpm ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.pnp.loader.mjs

# ─── Environment files ───────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ─── Turbo ───────────────────────────────────────────────────────────────────
.turbo/

# ─── Next.js ─────────────────────────────────────────────────────────────────
.next/
out/

# ─── PWA / Serwist (generated at build time) ─────────────────────────────────
**/public/sw.js
**/public/sw.js.map
**/public/workbox-*.js
**/public/workbox-*.js.map
**/public/swe-worker-*.js
**/public/swe-worker-*.js.map

# ─── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── Build outputs ───────────────────────────────────────────────────────────
build/
dist/

# ─── Test / coverage ─────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Vercel ──────────────────────────────────────────────────────────────────
.vercel/

# ─── Rust / Cargo ────────────────────────────────────────────────────────────
target/
# Rust backup files created by rustfmt
**/*.rs.bk

# ─── Python / uv ─────────────────────────────────────────────────────────────
.venv/
__pycache__/
*.py[cod]
*$py.class
*.pyd
*.egg-info/
*.egg
.eggs/

# ─── Python test / lint caches ───────────────────────────────────────────────
.pytest_cache/
.ruff_cache/
.mypy_cache/
.dmypy.json

# ─── Python coverage ─────────────────────────────────────────────────────────
htmlcov/
.coverage
.coverage.*
coverage.xml

# ─── Dagster ─────────────────────────────────────────────────────────────────
$DAGSTER_HOME/
dagster_home/
dagster-workspace.yaml.local

# ─── Editors — JetBrains ─────────────────────────────────────────────────────
.idea/
*.iml
*.iws

# ─── Editors — VS Code ───────────────────────────────────────────────────────
# Uncomment if you prefer not to share workspace settings:
# .vscode/

# ─── Editors — Vim / Neovim ──────────────────────────────────────────────────
*.swp
*.swo
*.swn
Session.vim
.netrwhist

# ─── Editors — Emacs ─────────────────────────────────────────────────────────
*~
\#*\#
.\#*

# ─── OS — macOS ──────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ─── OS — Windows ────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
desktop.ini

# ─── OS — Linux ──────────────────────────────────────────────────────────────
.directory

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Certificates / secrets ──────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx